# Root-level environment for dockerized backend + PostgreSQL scaffold.

# Frontend
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:38080

# Docker PostgreSQL
POSTGRES_DB=capcutai
POSTGRES_USER=capcutai
POSTGRES_PASSWORD=capcutai
POSTGRES_PORT=55432

# Backend
BACKEND_PORT=8080
BACKEND_HOST_PORT=38080
DB_URL=jdbc:postgresql://localhost:5432/capcutai
DB_USERNAME=capcutai
DB_PASSWORD=capcutai
APP_STORAGE_ROOT=storage

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_HOST_PORT=38000
AI_SERVICE_BASE_URL=http://localhost:38000

# Default local provider:
# 1. install Ollama
# 2. run: ollama pull qwen2.5:7b
# 3. run: ollama serve
LLM_PROVIDER=ollama
LLM_MODEL=
LLM_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Render Service
RENDER_SERVICE_PORT=3001
